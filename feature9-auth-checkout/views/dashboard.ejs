<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dashboard</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <nav class="navbar navbar-dark bg-dark">
    <div class="container">
      <span class="navbar-brand">Welcome, <%= user.username %></span>
      <a class="btn btn-outline-light btn-sm" href="/logout">Logout</a>
    </div>
  </nav>
  <div class="container py-5">
    <div class="row g-4">
      <div class="col-md-8">
        <div class="card shadow">
          <div class="card-body">
            <h3>Daily Macro Summary</h3>
            <p class="text-muted">Date: <%= today %></p>
            <% if (message) { %><div class="alert alert-success"><%= message %></div><% } %>
            <ul class="list-group">
              <li class="list-group-item">Calories: <strong><%= summary.consumed_calories %></strong></li>
              <li class="list-group-item">Protein: <strong><%= summary.consumed_protein_g %>g</strong></li>
              <li class="list-group-item">Carbs: <strong><%= summary.consumed_carbs_g %>g</strong></li>
              <li class="list-group-item">Fats: <strong><%= summary.consumed_fats_g %>g</strong></li>
            </ul>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card shadow">
          <div class="card-body">
            <h5>Quick Actions</h5>
            <a class="btn btn-primary w-100 mb-2" href="/checkout">Go to Checkout</a>
            <a class="btn btn-outline-secondary w-100" href="/logout">Logout</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
