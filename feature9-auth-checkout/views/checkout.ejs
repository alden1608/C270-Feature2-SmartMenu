<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Checkout</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <nav class="navbar navbar-dark bg-dark">
    <div class="container">
      <span class="navbar-brand">Checkout</span>
      <a class="btn btn-outline-light btn-sm" href="/logout">Logout</a>
    </div>
  </nav>
  <div class="container py-5">
    <div class="row justify-content-center">
      <div class="col-md-8">
        <div class="card shadow">
          <div class="card-body p-4">
            <h3 class="mb-3">Place an Order</h3>
            <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>
            <% if (success) { %><div class="alert alert-success"><%= success %></div><% } %>
            <form method="POST" action="/checkout">
              <div class="mb-3">
                <label class="form-label">Select a Meal</label>
                <select class="form-select" name="meal_name" required>
                  <% meals.forEach(function(meal) { %>
                    <option value="<%= meal.meal_name %>"><%= meal.meal_name %> — <%= meal.calories %> kcal</option>
                  <% }); %>
                </select>
              </div>
              <button class="btn btn-success">Place Order</button>
              <a class="btn btn-outline-secondary ms-2" href="/dashboard">Back to Dashboard</a>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
